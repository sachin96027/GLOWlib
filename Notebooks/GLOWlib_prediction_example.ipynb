# Step 1: Load libraries
import joblib
import numpy as np
import pandas as pd

# Step 2: Load the pre-trained model and scaler
model = joblib.load('models/Landsat8_Chla_RF.pkl')
scaler = joblib.load('scalers/Landsat8_Chla_scaler.pkl')

# Step 3: Prepare your input data
# Band ratios: [blue/green, green/red, red/NIR, 
#               NIR/red, coastal/red, NDVI-like]
X = pd.DataFrame({
    'blue_green': [0.45],
    'green_red':  [0.82],
    'red_NIR':    [0.31],
    'NIR_red':    [3.21],
    'coastal_red':[0.55],
    'NDVI_like':  [0.12]
})

# Step 4: Scale the input
X_scaled = scaler.transform(X)

# Step 5: Predict
chla_pred = model.predict(X_scaled)
print(f"Predicted Chl-a: {chla_pred[0]:.2f} mg m⁻³")
